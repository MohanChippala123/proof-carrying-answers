# Copy to .env (local) or set as Railway service variables.

# Turn the local small-model generator on. Without this, the app runs the
# deterministic verifier only (still fully functional, zero cost).
ENABLE_LOCAL_LLM=1

# Model (CPU-only GGUF). Defaults shown — fits 8 vCPU / 8 GB RAM.
LOCAL_MODEL_REPO=Qwen/Qwen2.5-1.5B-Instruct-GGUF
LOCAL_MODEL_FILE=qwen2.5-1.5b-instruct-q4_k_m.gguf
MODEL_N_CTX=4096
# MODEL_N_THREADS defaults to all cores; set explicitly to cap CPU use.
# MODEL_N_THREADS=8

# Persist the downloaded GGUF across restarts by pointing HF cache at a volume.
# HF_HOME=/data/hf

# Railway injects PORT automatically; only set for local dev if you want.
# PORT=5070
